{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "ignorePaths": ["**/ui/**", "**/.devcontainer/**"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/build-images.sh/"],
      "matchStrings": ["docker\\.io/nginx:(?<currentValue>[-0-9\\.a-z]+)"],
      "datasourceTemplate": "docker",
      "depNameTemplate": "nginx"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/build-images.sh/"],
      "matchStrings": ["docker\\.io/postgres:(?<currentValue>[-0-9\\.a-z]+)"],
      "datasourceTemplate": "docker",
      "depNameTemplate": "postgres"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/build-images.sh/"],
      "matchStrings": ["ghcr\\.io/mealie-recipes/mealie:(?<currentValue>[-0-9\\.a-z]+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "mealie-recipes/mealie"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["postgres"],
      "allowedVersions": "<= 16.0"
    }
  ]
}
